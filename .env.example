# Environment variables for Flask blog application
# Copy this file to .env and fill in actual values
# NEVER commit .env to git - it contains secrets!

# Flask session signing key (required)
# Must be at least 64 random characters for security
# Used for: Flask session cookie signing, CSRF protection
# Validation: Must be set, length >= 64 characters
SECRET_KEY=your-secret-key-here-change-this-to-at-least-64-random-characters-for-production

# Database connection URL (required)
# SQLite database file path (relative to project root)
# Used for: SQLAlchemy database connection (future phase)
# Validation: Must be a valid SQLite URL format
DATABASE_URL=sqlite:///instance/blog.db

# Debug mode (required)
# Controls Flask debug features and error pages
# Set to 'true' for development, 'false' for production
# Used for: Flask debug mode, auto-reload, detailed error pages
# Validation: Must be 'true' or 'false' (case-insensitive)
DEBUG=false

# Log level (required)
# Controls application logging verbosity
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Used for: Python logging configuration
# Validation: Must be valid Python log level
LOG_LEVEL=INFO

# Future environment variables (to be added in later phases):
# - BLOG_TITLE: Site title displayed in browser tab
# - BLOG_DESCRIPTION: Site meta description for SEO
# - ADMIN_PASSWORD_HASH: Hashed password for admin login (Phase 2)
# - POSTS_DIR: Directory containing Markdown blog posts (Phase 3)